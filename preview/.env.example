# Local preview server
PREVIEW_PORT=3060

# api = call a linked demo-store tenant through the local Node proxy.
# mock = use preview/mock/* data only.
PREVIEW_DATA_MODE=api

# Linked demo-store tenant domain for this theme http://demo.localhost:8000.
PREVIEW_API_BASE=https://azzrk.dev.gosharry.com
# Domain azzrk.localhost:8000
PREVIEW_THEME_DOMAIN=azzrk.dev.gosharry.com
PREVIEW_API_LOCALE=ar

# source = local customizer writes to theme.json / section {% schema %} / preview/state.json.
PREVIEW_WRITE_MODE=source

# Bearer token for the authenticated local-preview API sk_prev_s2jaFfoTaExtURVZyIw1bk8FNCKY9Q3JVRpopsVk.
# Generate one at: https://dev.gosharry.com/developers/settings/api-tokens (Media uploaded to store related to this token)
PREVIEW_API_TOKEN=sk_prev_your_token_here
