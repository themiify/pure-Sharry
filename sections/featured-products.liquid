{% assign is_rtl = request.is_rtl %}
{% assign c = section.settings %}
{% if is_rtl %}
  {% assign section_title = c.section_title_ar | default: c.section_title_en %}
{% else %}
  {% assign section_title = c.section_title_en | default: c.section_title_ar %}
{% endif %}
{% assign product_ids = c.products | default: empty %}
<section
  class="ro-products ro-products-{{ section.id }}"
  data-sal="slide-up"
  data-sal-delay="200"
  data-sal-duration="1000"
  {% if c.bg_switch and c.bg_img != blank %}
    style="background-image: url('{{ c.bg_img }}'); background-size: cover; background-position: center;"
  {% elsif c.bg_color != blank %}
    style="background-color: {{ c.bg_color }};"
  {% endif %}
>
  <div class="ro-container gl-container">
    {% if section_title != blank %}
      <div class="osh-section-head ">
    
        <h2
          class="ro-products__title"
            style="color: {{ c.title_color }};"
        >
          {{ section_title }}
        </h2>
     
      </div>
    {% endif %}
    {% if c.is_moving %}
      <div class="ro-products__slider-wrap">
        <div class="swiper ro-products__swiper ro-products__swiper-{{ section.id }}">
          <div class="swiper-wrapper">
            {% for product_id in product_ids %}
              <div class="swiper-slide">
                {% render 'product-card',
                  product_card_id: product_id,
                  product_card_api_url: api_routes.product_card_html,
                  product_card_orientation: 'vertical',
                  product_card_actions: 'view,addToCart,wishlist',
                  theme: theme,
                  shop: shop
                %}
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
    {% else %}
      <div class="ro-products__grid" style="--ro-cols: {{ c.grid_cols_number | default: 4 }};">
        {% for product_id in product_ids %}
          {% render 'product-card',
            product_card_id: product_id,
            product_card_api_url: api_routes.product_card_html,
            product_card_orientation: 'vertical',
            product_card_actions: 'view,addToCart,wishlist',
            theme: theme,
            shop: shop
          %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>
{% if c.is_moving %}
  <script>
        (function () {
            var el = document.querySelector('.ro-products__swiper-{{ section.id }}');
            if (!el || typeof Swiper === 'undefined') return;
            new Swiper(el, {
                speed: 1000, spaceBetween: 14,
                autoplay: {% if c.isp_autoPlay %}{ delay: 3000, disableOnInteraction: false, pauseOnMouseEnter: true }{% else %}false{% endif %},
        breakpoints: { 0: { slidesPerView: 2 }, 786: { slidesPerView: 3 }, 1024: { slidesPerView: {{ c.grid_cols_number | default: 4 }} } }
      });
    }) ();
  </script>
{% endif %}
<style>
  .ro-products {
    padding: 24px 0;
  }
.ro-products .swiper-slide{
max-width: 300px !important;
height: auto;
}
.ro-products .pc--vertical{
  height: 100%;
}
.ro-products .pc__body {
  justify-content: space-between;
}
  .ro-products__title {
    font-size: 1.5rem;
    font-weight: 700;
    text-align: center;
  }

  .ro-products__grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(2, 1fr);
  }

  @media (min-width: 786px) {
    .ro-products__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .ro-products__grid {
      grid-template-columns: repeat(var(--ro-cols, 4), 1fr);
    }
  }

  .ro-products__slider-wrap {
    position: relative;
  }

  .ro-products__pagination {
    position: relative !important;
    bottom: 0 !important;
    margin-top: 16px;
  }
</style>
