{% comment %}
  Interactive Gallery Section — Sportify Theme
  Mixed grid: product cards (via render) + custom banner cards.
  5 items: item 2 is tall (spans 2 rows).

  IMPORTANT — how products work in Sharry vs Zid:
  Zid:   item.product gives full object (images, price, url…) — rendered in Liquid directly.
  Sharry: only product IDs are available inside a repeater field.
          Full card HTML is fetched via JS (product_card_api_url) and hydrated client-side.
          So each product slot renders a loading skeleton → JS fills it in.

  CSS    → assets/css/glamour-pro.css  (search: SP Interactive Gallery)
  JS     → assets/js/sp-interactive-gallery.js
  Schema → theme.json  (slug: sp-interactive-gallery)
{% endcomment %}

{% assign is_rtl = request.is_rtl %}

{% assign animation = '' %}
{% if section.settings.animation_enable %}
  {% if section.settings.animation_type == 'random' %}
    {% assign animation = 'fade-up' %}
  {% else %}
    {% assign animation = section.settings.animation_type %}
  {% endif %}
{% endif %}

<section
  class="sp-ig-section gl-section"
  id="section-{{ section.id }}"
  data-section="sp-interactive-gallery"
  data-add-to-cart-url="{{ api_routes.cart_store }}"
  data-wishlist-url="{{ api_routes.wishlist_store }}"
  style="{% if section.settings.margin_switch %}margin: 0 !important; padding: 0 !important;{% endif %}"
>
  <div class="gl-container">
    <div class="sp-ig-grid">
      {% for item in section.settings.banner_products %}
        {% assign main_text = item.main_text %}
        {% if is_rtl and item.main_text_ar != blank %}
          {% assign main_text = item.main_text_ar %}
        {% endif %}

        {% assign sub_text = item.sub_text %}
        {% if is_rtl and item.sub_text_ar != blank %}
          {% assign sub_text = item.sub_text_ar %}
        {% endif %}

        {% assign btn_text = item.btn_text %}
        {% if is_rtl and item.btn_text_ar != blank %}
          {% assign btn_text = item.btn_text_ar %}
        {% endif %}

        <div
          class="sp-ig-item {% if forloop.index == 2 %}sp-ig-item--tall{% endif %}"
          {% if section.settings.animation_enable and animation != blank %}
            data-aos="{{ animation }}"
            data-aos-duration="{{ section.settings.animation_duration | default: 1200 }}"
            data-aos-delay="{{ forloop.index0 | times: 100 }}"
          {% endif %}
        >
          {% comment %} ─── Product Card ─── {% endcomment %}
          {% unless item.add_banner %}
            {% if item.product_id != blank %}
              {% render 'product-card',
                product_card_id: item.product_id,
                product_card_api_url: api_routes.product_card_html,
                product_card_orientation: 'vertical',
                product_card_actions: 'view,addToCart,wishlist,compare',
                theme: theme,
                shop: shop
              %}
            {% else %}
              {% comment %} Placeholder when no product selected {% endcomment %}
              <div
                class="gl-product-card"
                style="background: {{ section.settings.background_color_card | default: '#ffffff' }};"
              >
                <div class="gl-product-card-image">
                  <div class="gl-product-placeholder"></div>
                </div>
                <div class="gl-product-card-body">
                  <div class="gl-skeleton gl-skeleton-title"></div>
                  <div class="gl-skeleton gl-skeleton-description"></div>
                </div>
              </div>
            {% endif %}
          {% endunless %}

          {% comment %} ─── Banner Card ─── {% endcomment %}
          {% if item.add_banner %}
            <div class="sp-ig-banner" style="background: {{ item.layout_color | default: '#111f4d' }};">
              {% if main_text != blank %}
                <h2 class="sp-ig-banner__title" style="color: {{ item.main_text_color | default: '#ffffff' }};">
                  {{ main_text }}
                </h2>
              {% endif %}
              {% if sub_text != blank %}
                <p class="sp-ig-banner__subtitle" style="color: {{ item.sub_text_color | default: '#ffffff' }};">
                  {{ sub_text }}
                </p>
              {% endif %}
              {% if btn_text != blank %}
                <a href="{{ item.btn_url | default: '#' }}">
                  <button
                    class="sp-ig-banner__btn"
                    style="
                      background-color: {% if item.background_transparent %}transparent{% else %}{{ item.btn_color | default: 'transparent' }}{% endif %};
                      border: 1px solid {{ item.btn_border_color | default: '#ffffff' }};
                      color: {{ item.btn_text_color | default: '#ffffff' }};
                    "
                  >
                    {{ btn_text }}
                  </button>
                </a>
              {% endif %}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

