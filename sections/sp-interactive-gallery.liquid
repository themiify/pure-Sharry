<style>
  /* ============================================
   SP Interactive Gallery — Sportify Theme
   ============================================ */

.sp-ig-section {
  padding-block: 40px;
}

/* ── 5-cell CSS Grid ─────────────────────────
   Layout:
   [1]      [2 tall]  [3]
   [4]      [2 tall]  [5]
   ─────────────────────────────────────────── */
.sp-ig-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-template-rows: auto auto;
  gap: 16px;
}

.sp-ig-item:nth-child(2) {
  grid-row: span 2;
}

/* ── Grid Cell ── */
.sp-ig-item {
  border-radius: var(--gl-radius, 12px);
  overflow: hidden;
  position: relative;
  min-height: 220px;
}

/* ── Product Card inside cell — image fills the cell ── */
.sp-ig-item .gl-product-card {
  height: 100%;
  min-height: 220px;
  display: flex;
  flex-direction: column;
  border-radius: var(--gl-radius, 12px);
  overflow: hidden;
  box-shadow: var(--gl-shadow-sm, 0 2px 8px rgba(0, 0, 0, 0.06));
  position: relative;
}

.sp-ig-item .gl-product-card-image {
  flex: 1;
  min-height: 180px;
  overflow: hidden;
}

.sp-ig-item .gl-product-card-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease;
}

.sp-ig-item:hover .gl-product-card-image img {
  transform: scale(1.04);
}

/* Tall item (index 2) — bigger image */
.sp-ig-item--tall .gl-product-card-image {
  min-height: 380px;
}

.sp-ig-item--tall .gl-product-card {
  min-height: 100%;
}

/* ── Direct Image Link (item_image field) ── */
.sp-ig-image-link {
  display: block;
  height: 100%;
  min-height: 220px;
  overflow: hidden;
  border-radius: var(--gl-radius, 12px);
}

.sp-ig-image-link img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease;
}

.sp-ig-item:hover .sp-ig-image-link img {
  transform: scale(1.04);
}

.sp-ig-item--tall .sp-ig-image-link {
  min-height: 100%;
}

.sp-ig-placeholder {
  background: #f5f5f5;
}

/* ── Loading skeleton ── */
.sp-ig-item .gl-product-placeholder {
  width: 100%;
  height: 100%;
  min-height: 180px;
  background: #f0f0f0;
  border-radius: var(--gl-radius, 12px);
  animation: sp-ig-shimmer 1.5s infinite linear;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
}

@keyframes sp-ig-shimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ── Banner Card ── */
.sp-ig-banner {
  height: 100%;
  min-height: 220px;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  padding: 28px 24px;
  border-radius: var(--gl-radius, 12px);
  gap: 12px;
}

[dir="rtl"] .sp-ig-banner {
  align-items: flex-end;
  text-align: right;
}

.sp-ig-item--tall .sp-ig-banner {
  min-height: 100%;
}

.sp-ig-banner__title {
  font-size: clamp(1.3rem, 1rem + 1.2vw, 2.1rem);
  font-weight: 700;
  line-height: 1.3;
  font-family: var(--gl-font-heading, 'Cairo', sans-serif);
  margin: 0;
}

.sp-ig-banner__subtitle {
  font-size: clamp(0.85rem, 0.78rem + 0.3vw, 1rem);
  line-height: 1.7;
  opacity: 0.88;
  margin: 0;
  font-family: var(--gl-font-body, 'Cairo', sans-serif);
}

.sp-ig-banner__btn {
  margin-top: 8px;
  padding: 9px 26px;
  font-size: 0.9rem;
  font-weight: 600;
  cursor: pointer;
  border-radius: 6px;
  transition: opacity 0.25s ease, transform 0.25s ease;
  font-family: var(--gl-font-body, 'Cairo', sans-serif);
  letter-spacing: 0.02em;
}

.sp-ig-banner__btn:hover {
  opacity: 0.8;
  transform: translateY(-2px);
}

/* ── Responsive ── */
@media (max-width: 992px) {
  .sp-ig-grid {
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: auto;
  }

  .sp-ig-item:nth-child(2) {
    grid-row: span 1;
  }

  .sp-ig-item--tall .gl-product-card-image {
    min-height: 220px;
  }
}

@media (max-width: 576px) {
  .sp-ig-section {
    padding-block: 24px;
  }

  .sp-ig-grid {
    grid-template-columns: 1fr;
    gap: 12px;
  }

  .sp-ig-item {
    min-height: 200px;
  }

  .sp-ig-item--tall .gl-product-card-image {
    min-height: 200px;
  }

  .sp-ig-banner {
    min-height: 200px;
    padding: 22px 20px;
  }
}
</style>