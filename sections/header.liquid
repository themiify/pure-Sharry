{% comment %}
  Header Section — Glamour Theme v2.1
  Main site navigation, logo, and utilities.
{% endcomment %}

{% assign is_rtl = request.is_rtl %}
{% assign is_sticky = section.settings.sticky  %}
{% assign show_search = section.settings.search_enabled  %}
{% assign show_cart = section.settings.cart_enabled  %}
{% assign show_announcement = section.settings.show_announcement  %}
{% assign show_fav = section.settings.show_fav  %}
{% assign cart_items_count = cart.items_count | default: 0 %}
{% assign wishlist_items_count = wishlist.items_count | default: 0 %}
{% assign header_menu = section.menu %}


{% if header_menu == blank %}
  {% assign header_menu = menus.main %}
{% endif %}



{% if show_announcement and section.settings.announcement_text != blank %}
  <div class="gl-announcement">
    <div class="header-marquee-content">
      <span class="gl-announcement-text"> {% if is_rtl %} {{ section.settings.announcement_text_ar }} {% else %}  {{ section.settings.announcement_text }} {% endif %}</span>
      <span class="gl-announcement-text"> {% if is_rtl %} {{ section.settings.announcement_text_ar }} {% else %}  {{ section.settings.announcement_text }} {% endif %}</span>
      <span class="gl-announcement-text"> {% if is_rtl %} {{ section.settings.announcement_text_ar }} {% else %}  {{ section.settings.announcement_text }} {% endif %}</span>
      <span class="gl-announcement-text"> {% if is_rtl %} {{ section.settings.announcement_text_ar }} {% else %}  {{ section.settings.announcement_text }} {% endif %}</span>
      <span class="gl-announcement-text"> {% if is_rtl %} {{ section.settings.announcement_text_ar }} {% else %}  {{ section.settings.announcement_text }} {% endif %}</span>
      <span class="gl-announcement-text"> {% if is_rtl %} {{ section.settings.announcement_text_ar }} {% else %}  {{ section.settings.announcement_text }} {% endif %}</span>
    </div>
  </div>
{% endif %}

<div class="top-header">
  <div class="gl-container top-header-inner">
    <div class="contact-info">
      <span>
