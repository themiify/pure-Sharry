{% comment %}
  Beauty Tips Section — Glamour Theme v2.1
  Displays up to 3 featured articles or beauty guides.
{% endcomment %}

{% assign is_rtl = request.is_rtl %}
{% assign heading = section.settings.heading | default: 'Beauty Tips & Guides' %}
{% assign heading_ar = section.settings.heading_ar | default: 'نصائح ودليل الجمال' %}
{% assign article_count = section.settings.article_count | default: 3 %}

<section
  class="gl-section gl-beauty-tips"
  style="background-color: var(--gl-bg);{% if section.settings.heading_font_override != blank %}--section-font-heading: '{{ section.settings.heading_font_override }}', sans-serif;{% endif %}{% if section.settings.body_font_override != blank %}--section-font-body: '{{ section.settings.body_font_override }}', sans-serif;{% endif %}{% if section.settings.heading_font_size > 0 %}--section-heading-size: {{ section.settings.heading_font_size }}px;{% endif %}{% if section.settings.body_font_size > 0 %}--section-body-size: {{ section.settings.body_font_size }}px;{% endif %}{% assign pad = section.settings.section_padding %}{% if section.settings.section_bg_color != blank %}background-color: {{ section.settings.section_bg_color }};{% endif %} "
>
  <div class="gl-container">
    <div class="gl-section-header">
      <h2>
        {% if is_rtl %}{{ heading_ar }}{% else %}{{ heading }}{% endif %}
      </h2>
    </div>

    <div class="gl-tips-grid">
      {% assign has_tips = false %}
      {% for i in (1..3) %}
        {% if i <= article_count %}
          {% assign title_key = 'tip' | append: i | append: '_title' %}
          {% assign title_ar_key = 'tip' | append: i | append: '_title_ar' %}
          {% assign excerpt_key = 'tip' | append: i | append: '_excerpt' %}
          {% assign excerpt_ar_key = 'tip' | append: i | append: '_excerpt_ar' %}
          {% assign image_key = 'tip' | append: i | append: '_image' %}
          {% assign url_key = 'tip' | append: i | append: '_url' %}

          {% assign title = section.settings[title_key] %}
          {% assign title_ar = section.settings[title_ar_key] %}
          {% assign excerpt = section.settings[excerpt_key] %}
          {% assign excerpt_ar = section.settings[excerpt_ar_key] %}
          {% assign image = section.settings[image_key] %}
          {% assign url = section.settings[url_key] | default: '#' %}

          {% assign display_title = title %}
          {% assign display_excerpt = excerpt %}

          {% if is_rtl %}
            {% assign display_title = title_ar | default: title %}
            {% assign display_excerpt = excerpt_ar | default: excerpt %}
          {% endif %}

          {% if display_title != blank %}
            {% assign has_tips = true %}
            <article class="gl-tip-card">
              <a href="{{ url }}">
                <div class="gl-tip-card-image">
                  {% if image %}
                    <img src="{{ image }}" alt="{{ display_title }}" loading="lazy">
                  {% else %}
                    <div
                      style="width:100%;height:100%;min-height:200px;background: linear-gradient(135deg, var(--gl-secondary), var(--gl-primary-light));"
                    ></div>
                  {% endif %}
                </div>
                <div class="gl-tip-card-body">
                  <h3 class="gl-tip-card-title">{{ display_title }}</h3>
                  <p class="gl-tip-card-excerpt">{{ display_excerpt }}</p>
                  <span class="gl-tip-card-link">
                    {% if is_rtl %}اقرأي المزيد &larr;{% else %}Read More &rarr;{% endif %}
                  </span>
                </div>
              </a>
            </article>
          {% endif %}
        {% endif %}
      {% endfor %}

      {% if has_tips == false %}
        <!-- Preview placeholders -->
        <article class="gl-tip-card">
          <div class="gl-tip-card-image">
            <div
              style="width:100%;height:100%;min-height:200px;background: linear-gradient(135deg, #FCE4EC, #F06292);"
            ></div>
          </div>
          <div class="gl-tip-card-body">
            <h3 class="gl-tip-card-title">
              {% if is_rtl %}كيفية اختيار كريم الأساس المناسب{% else %}How to Choose the Right Foundation{% endif %}
            </h3>
            <p class="gl-tip-card-excerpt">
              {% if is_rtl -%}
                دليل شامل لاختيار درجة كريم الأساس المناسبة لبشرتك
              {%- else -%}
                A complete guide to finding your perfect shade match
              {%- endif %}
            </p>
            <span class="gl-tip-card-link">
              {%- if is_rtl %}اقرأي المزيد &larr;{% else %}Read More &rarr;{% endif -%}
            </span>
          </div>
        </article>
        <article class="gl-tip-card">
          <div class="gl-tip-card-image">
            <div
              style="width:100%;height:100%;min-height:200px;background: linear-gradient(135deg, #FFF8FA, #E91E63);"
            ></div>
          </div>
          <div class="gl-tip-card-body">
            <h3 class="gl-tip-card-title">
              {% if is_rtl %}روتين العناية بالبشرة المسائي{% else %}Evening Skincare Routine{% endif %}
            </h3>
            <p class="gl-tip-card-excerpt">
              {% if is_rtl -%}
                خطوات بسيطة للحصول على بشرة مشرقة كل صباح
              {%- else -%}
                Simple steps for glowing skin every morning
              {%- endif %}
            </p>
            <span class="gl-tip-card-link">
              {%- if is_rtl %}اقرأي المزيد &larr;{% else %}Read More &rarr;{% endif -%}
            </span>
          </div>
        </article>
        <article class="gl-tip-card">
          <div class="gl-tip-card-image">
            <div
              style="width:100%;height:100%;min-height:200px;background: linear-gradient(135deg, #D4AF37, #FCE4EC);"
            ></div>
          </div>
          <div class="gl-tip-card-body">
            <h3 class="gl-tip-card-title">
              {% if is_rtl %}أفضل ألوان أحمر الشفاه لعام 2026{% else %}Top Lipstick Trends for 2026{% endif %}
            </h3>
            <p class="gl-tip-card-excerpt">
              {% if is_rtl -%}
                اكتشفي أحدث صيحات ألوان الشفاه لهذا الموسم
              {%- else -%}
                Discover the hottest lip colors this season
              {%- endif %}
            </p>
            <span class="gl-tip-card-link">
              {%- if is_rtl %}اقرأي المزيد &larr;{% else %}Read More &rarr;{% endif -%}
            </span>
          </div>
        </article>
      {% endif %}
    </div>
  </div>
</section>
