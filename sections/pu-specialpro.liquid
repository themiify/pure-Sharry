{% assign c = section.settings %}

{% if request.is_rtl %}
  {% assign section_pro_title = c.pro_title_ar | default: c.pro_title_en %}
  {% assign section_main_title = c.main_title_ar | default: c.main_title_en %}
{% else %}
  {% assign section_pro_title = c.pro_title_en | default: c.pro_title_ar %}
  {% assign section_main_title = c.main_title_en | default: c.main_title_ar %}
{% endif %}

{% assign has_first = false %}
{% if c.first_video_url != blank or c.first_side_image != blank %}
  {% assign has_first = true %}
{% endif %}

{% assign has_second = false %}
{% if c.second_video_url != blank or c.second_side_image != blank %}
  {% assign has_second = true %}
{% endif %}

{% assign banners_count = 0 %}
{% if has_first %}{% assign banners_count = banners_count | plus: 1 %}{% endif %}
{% if has_second %}{% assign banners_count = banners_count | plus: 1 %}{% endif %}

{% assign show_side_banners = false %}
{% if banners_count > 0 %}{% assign show_side_banners = true %}{% endif %}

<section class="puspecial pu-{{ section.id }} {% unless c.disable_space_between_components %}pu--spaced{% endunless %} animate-component">
  <div class="pu__container gl-container">

    <div class="pu__main-banner {% if show_side_banners %}{% if banners_count == 2 %}pu__main-banner--third{% else %}pu__main-banner--half{% endif %}{% else %}pu__main-banner--full{% endif %}"
         style="background-color: {% if c.toggle_theme_color_main_banner %}{{ c.main_banner_bg }}{% else %}var(--color-primary){% endif %};"
         data-aos="fade-left" data-aos-delay="200" data-aos-duration="2000">
      <p class="pu__pro-title">{{ section_pro_title }}</p>
      <h3 class="pu__main-title">{{ section_main_title }}</h3>
      {% for product_id in c.special_product %}
        <div class="pu__product-card">
          {% render 'product-card',
            product_card_id: product_id,
            product_card_api_url: api_routes.product_card_html,
            product_card_orientation: 'horizontal',
            product_card_actions: 'view,addToCart,wishlist',
            theme: theme,
            shop: shop %}
        </div>
      {% endfor %}
    </div>

    {% if show_side_banners %}
      <div class="pu__side-banners {% if banners_count == 2 %}pu__side-banners--two-thirds{% else %}pu__side-banners--half{% endif %}"
           data-aos="fade-up" data-aos-delay="200" data-aos-duration="2000">

        {% if has_first %}
          <div class="pu__side-banner {% if banners_count == 2 %}pu__side-banner--half{% else %}pu__side-banner--full{% endif %}">
            {% if c.first_video_url != blank %}
              <div class="pu__video-wrap">
                <video autoplay muted loop playsinline class="pu__video">
                  <source src="{{ c.first_video_url }}" type="video/mp4">
                </video>
              </div>
            {% else %}
              <div class="pu__image-wrap">
                <img src="{{ c.first_side_image }}" alt="" class="pu__image pu__image--hover">
              </div>
            {% endif %}
          </div>
        {% endif %}

        {% if has_second %}
          <div class="pu__side-banner {% if banners_count == 2 %}pu__side-banner--half{% else %}pu__side-banner--full{% endif %}"
               data-aos="fade-right" data-aos-delay="200" data-aos-duration="2000">
            {% if c.second_video_url != blank %}
              <div class="pu__video-wrap">
                <video autoplay muted loop playsinline class="pu__video">
                  <source src="{{ c.second_video_url }}" type="video/mp4">
                </video>
              </div>
            {% else %}
              <div class="pu__image-wrap">
                <img src="{{ c.second_side_image }}" alt="" class="pu__image pu__image--hover">
              </div>
            {% endif %}
          </div>
        {% endif %}

      </div>
    {% endif %}

  </div>
</section>
<style>
    .puspecial{
  padding: 24px 0;
}
 
.pu--spaced {
  margin-bottom: 40px;
}
 
/* Container */
.pu__container {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
 
@media (min-width: 768px) {
  .pu__container {
    flex-direction: row;
  }
}
 
/* ── Main Banner ── */
.pu__main-banner {
  width: 100%;
  padding: 0px 24px;
  border-radius: 8px;
  box-sizing: border-box;
}
.pu__main-banner .gl-product-card-action-btn.gl-add-to-cart-btn {
  visibility: visible !important;
  opacity: 1 !important;
  --tw-translate-x: 0 !important;
  --tw-translate-y: 0 !important;
}
 
@media (min-width: 768px) {
  .pu__main-banner--third {
    width: 33.333%;
  }
  .pu__main-banner--half {
    width: 50%;
  }
  .pu__main-banner--full {
    width: 100%;
  }
}
 
.pu__pro-title {
  font-weight: 400;
  font-size: 14px;
  padding-top:40px ;
  margin: 0 0 8px;
}
 
.pu__main-title {
  font-weight: 500;
  font-size: 28px;
  margin: 0 0 16px;
}
 

 
/* ── Side Banners ── */
.pu__side-banners {
  display: flex;
  flex-direction: row;
  gap: 8px;
  width: 100%;
}
 
@media (min-width: 768px) {
  .pu__side-banners--two-thirds {
    width: 66.666%;
  }
  .pu__side-banners--half {
    width: 50%;
  }
}
 
.pu__side-banner {
  overflow: hidden;
  border-radius: 8px;
}
 
.pu__side-banner--half {
  width: 50%;
}
 
.pu__side-banner--full {
  width: 100%;
}
 
/* ── Video ── */
.pu__video-wrap,
.pu__image-wrap {
  height: 166px;
  border-radius: 8px;
  overflow: hidden;
}
 
@media (min-width: 768px) {
  .pu__video-wrap,
  .pu__image-wrap {
    height: 100%;
  }
}
 
.pu__video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 8px;
  display: block;
}
 
/* ── Image ── */
.pu__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 8px;
  display: block;
}
 
.pu__image--hover {
  transition: transform 0.5s ease-in-out;
}
 
.pu__image--hover:hover {
  transform: scale(0.95);
}
</style>