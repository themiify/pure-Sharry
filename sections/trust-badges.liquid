{% comment %}
  Trust Badges Section — Glamour Theme v2.1
  Displays up to 4 trust badges or guarantees.
{% endcomment %}

{% assign is_rtl = request.is_rtl %}

<section
  class="gl-section-sm gl-trust-badges-section"
  style="background-color: var(--gl-bg);{% if section.settings.heading_font_override != blank %}--section-font-heading: '{{ section.settings.heading_font_override }}', sans-serif;{% endif %}{% if section.settings.body_font_override != blank %}--section-font-body: '{{ section.settings.body_font_override }}', sans-serif;{% endif %}{% if section.settings.heading_font_size > 0 %}--section-heading-size: {{ section.settings.heading_font_size }}px;{% endif %}{% if section.settings.body_font_size > 0 %}--section-body-size: {{ section.settings.body_font_size }}px;{% endif %}{% assign pad = section.settings.section_padding %}{% if section.settings.section_bg_color != blank %}background-color: {{ section.settings.section_bg_color }};{% endif %} "
>
  <div class="gl-container">
    <div class="gl-trust-badges">
      {% assign has_badges = false %}

      {% for i in (1..4) %}
        {% assign icon_key = 'badge' | append: i | append: '_icon' %}
        {% assign title_key = 'badge' | append: i | append: '_title' %}
        {% assign title_ar_key = 'badge' | append: i | append: '_title_ar' %}
        {% assign subtitle_key = 'badge' | append: i | append: '_subtitle' %}
        {% assign subtitle_ar_key = 'badge' | append: i | append: '_subtitle_ar' %}

        {% assign icon = section.settings[icon_key] %}
        {% assign title = section.settings[title_key] %}
        {% assign title_ar = section.settings[title_ar_key] %}
        {% assign subtitle = section.settings[subtitle_key] %}
        {% assign subtitle_ar = section.settings[subtitle_ar_key] %}

        {% assign display_title = title %}
        {% assign display_subtitle = subtitle %}

        {% if is_rtl %}
          {% assign display_title = title_ar | default: title %}
          {% assign display_subtitle = subtitle_ar | default: subtitle %}
        {% endif %}

        {% if display_title != blank %}
          {% assign has_badges = true %}
          <div class="gl-trust-badge">
            <div class="gl-trust-badge-icon">{{ icon | default: '✨' }}</div>
            <div>
              <h4 class="gl-trust-badge-title">{{ display_title }}</h4>
              {% if display_subtitle != blank %}
                <p class="gl-trust-badge-subtitle">{{ display_subtitle }}</p>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}

      {% if has_badges == false %}
        <div class="gl-trust-badge">
          <div class="gl-trust-badge-icon">🚚</div>
          <div>
            <h4 class="gl-trust-badge-title">
              {% if is_rtl %}شحن مجاني{% else %}Free Shipping{% endif %}
            </h4>
            <p class="gl-trust-badge-subtitle">
              {% if is_rtl %}للطلبات فوق 200 ر.س{% else %}On orders over $50{% endif %}
            </p>
          </div>
        </div>
        <div class="gl-trust-badge">
          <div class="gl-trust-badge-icon">🔒</div>
          <div>
            <h4 class="gl-trust-badge-title">
              {% if is_rtl %}دفع آمن{% else %}Secure Payment{% endif %}
            </h4>
            <p class="gl-trust-badge-subtitle">
              {% if is_rtl %}بطاقات ائتمان وآبل باي{% else %}SSL encrypted checkout{% endif %}
            </p>
          </div>
        </div>
        <div class="gl-trust-badge">
          <div class="gl-trust-badge-icon">↩️</div>
          <div>
            <h4 class="gl-trust-badge-title">
              {% if is_rtl %}إرجاع سهل{% else %}Easy Returns{% endif %}
            </h4>
            <p class="gl-trust-badge-subtitle">
              {% if is_rtl %}خلال 14 يوم{% else %}14-day return policy{% endif %}
            </p>
          </div>
        </div>
        <div class="gl-trust-badge">
          <div class="gl-trust-badge-icon">💬</div>
          <div>
            <h4 class="gl-trust-badge-title">
              {% if is_rtl %}دعم 24/7{% else %}24/7 Support{% endif %}
            </h4>
            <p class="gl-trust-badge-subtitle">
              {% if is_rtl %}واتساب ولايف تشات{% else %}WhatsApp & live chat{% endif %}
            </p>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</section>
