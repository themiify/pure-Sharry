{% comment %}
  Hero Banner Slider Section — Glamour Theme v2.1
  A striking first impression with full-bleed background slider, gradient overlay, and call-to-action.
  Each instance is scoped by section.id to prevent style leaking between multiple hero sections.
{% endcomment %}

{% assign is_rtl = request.is_rtl %}
<section id="hero-{{ section.id }}" class="hero-banners gl-section">
  <div class="swiper mySwiper-hero-banner main-banner">
    <div class="swiper-wrapper">
      {% for banner in section.settings.hero_banners %}
        {% assign bg_image = banner.bg_image %}
        {% if is_rtl and banner.bg_image_ar != blank %}
          {% assign bg_image = banner.bg_image_ar %}
        {% endif %}

        {% assign main_title = banner.main_title %}
        {% if is_rtl and banner.main_title_ar != blank %}
          {% assign main_title = banner.main_title_ar %}
        {% endif %}

        {% assign highlighted_text = banner.highlighted_text %}
        {% if is_rtl and banner.highlighted_text_ar != blank %}
          {% assign highlighted_text = banner.highlighted_text_ar %}
        {% endif %}

        {% assign highlighted_text_color = banner.highlighted_text_color | default: '#CE5A67' %}

        {% if highlighted_text != blank %}
          {% assign highlighted_text_wrapped = '**' | append: highlighted_text | append: '**' %}
        {% endif %}

        {% assign featured_image = banner.featured_image %}
        {% if is_rtl and banner.featured_image_ar != blank %}
          {% assign featured_image = banner.featured_image_ar %}
        {% endif %}

        {% assign sub_title = banner.sub_title %}
        {% if is_rtl and banner.sub_title_ar != blank %}
          {% assign sub_title = banner.sub_title_ar %}
        {% endif %}

        {% assign btn_text = banner.btn_text %}
        {% if is_rtl and banner.btn_text_ar != blank %}
          {% assign btn_text = banner.btn_text_ar %}
        {% endif %}

        {% assign text_align = banner.text_align | default: 'center' %}

        <div class="swiper-slide">
          {% if bg_image != blank %}
            <img src="{{ bg_image }}" alt="{{ main_title | default: 'Banner' }}" loading="lazy" class="banner-image">
          {% else %}
            <div
              style="width: 100%; height: 100%; background: linear-gradient(135deg, var(--gl-primary) 0%, var(--gl-primary-dark) 100%);"
            ></div>
          {% endif %}

          <div
            class="hero-content hero-content-{{ text_align }}"
            style="color: {{ banner.text_color | default: '#ffffff' }};"
          >
            {% if main_title != blank %}
              <h1
                data-sal="slide-up"
                data-sal-duration="700"
                data-sal-delay="100"
                data-sal-easing="ease-out-back"
              >
                {% if highlighted_text != blank %}
                  {% assign parts = main_title | split: highlighted_text %}
                  {{ parts[0] }}
                  <span class="highlighted-text" style="color: {{ highlighted_text_color }};">
                    {{ highlighted_text }}
                    {% assign featured_img = featured_image %}
                    {% if is_rtl and banner.featured_image_ar != blank %}
                      {% assign featured_img = banner.featured_image_ar %}
                    {% endif %}
                    {% if featured_img != blank %}
                      <img src="{{ featured_img }}" class="highlighted-img" alt="image-{{ forloop.index }}">
                    {% endif %}
                  </span>
                  {{ parts[1] }}
                {% else %}
                  {{ main_title }}
                {% endif %}
              </h1>
            {% endif %}
            {% if sub_title != blank %}
              <p
                data-sal="slide-up"
                data-sal-duration="700"
                data-sal-delay="250"
              >
                {{ sub_title }}
              </p>
            {% endif %}

            {% if btn_text != blank and banner.btn_url != blank %}
              <a
                data-sal="slide-up"
                data-sal-duration="700"
                data-sal-delay="400"
                href="{{ banner.btn_url }}"
                class="gl-btn"
              >
                <span>{{ btn_text }}</span>
              </a>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>

    <div class="swiper-pagination swiper-pagination-hero-banner"></div>
  </div>
</section>

<script>
  var swiper = new Swiper('.mySwiper-hero-banner', {
    effect: 'fade',
    grabCursor: true,
    loop: false,
    speed: 700,
    autoplay: {
      delay: 3000,
      disableOnInteraction: false,
    },
    pagination: {
      el: '.swiper-pagination-hero-banner',
      clickable: true,
    },
  });
</script>


