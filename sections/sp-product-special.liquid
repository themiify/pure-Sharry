                        }
                    ]
                }
            ]
        }
    ],
    "defaults": {
        "margin_switch": false,
        "background_top_section": "https://media.zid.store/1cf34273-59ed-45ac-b06d-6aaa51dbb818/d5f6ce1d-eff5-4ffc-abb6-149a82f09c94.webp",
