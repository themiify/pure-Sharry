<style>
#floating-whatsapp {
  position: fixed;
  width: 45px;
  height: 45px;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  cursor: grab;
  z-index: 99999;
  transition: transform 0.2s ease, left 0.2s ease, top 0.2s ease;
  user-select: none;
  background: transparent;
}


.pulse.delay1 { animation-delay: 0.5s; }
.pulse.delay2 { animation-delay: 1s; }

.pulse {
  position: absolute;
  width: 45px;
  height: 45px;
  border: 2px solid #a0d9b0; 
  border-radius: 50%;
  opacity: 0;
  animation: pulseWave 2.5s infinite;
}

@keyframes pulseWave {
  0% { transform: scale(1); opacity: 0.4; }  
  70% { transform: scale(2); opacity: 0; }  
  100% { transform: scale(2.2); opacity: 0; }
}

#floating-whatsapp svg {
  width: 40px;
  height: 40px;
  pointer-events: none;
  z-index: 10;
}

#floating-whatsapp:active {
  transform: scale(0.95);
}
</style>


<script>
document.addEventListener('DOMContentLoaded', () => {
  const icon = document.getElementById('floating-whatsapp');
  const saved = JSON.parse(localStorage.getItem('whatsappPosition'));

  let offsetX, offsetY, isDown = false, moved = false;
  let startX, startY;
  let overlay;

  function getScrollbarWidth() {
    return window.innerWidth - document.documentElement.clientWidth;
  }

  function setInitialPosition() {
    const iconRect = icon.getBoundingClientRect();
    const windowWidth = window.innerWidth;
    const windowHeight = window.innerHeight;
    const scrollbarWidth = getScrollbarWidth();

    const iconWidth = iconRect.width;
    const iconHeight = iconRect.height;

    if (saved) {
      let left = (windowWidth - iconWidth - scrollbarWidth) * saved.leftPercent / 100;
      let top = (windowHeight - iconHeight) * saved.topPercent / 100;

      left = Math.min(Math.max(left, 0), windowWidth - iconWidth - scrollbarWidth);
      top = Math.min(Math.max(top, 0), windowHeight - iconHeight);

      icon.style.left = left + 'px';
      icon.style.top = top + 'px';

    } else {
      icon.style.left = (windowWidth - iconWidth - scrollbarWidth - 20) + 'px';
      icon.style.top = (windowHeight - iconHeight - 150) + 'px';
    }
  }

  setInitialPosition();
  window.addEventListener('resize', setInitialPosition);

  function startDrag(e) {
    isDown = true;
    moved = false;
    icon.style.transition = 'none';

    overlay = document.createElement('div');
    Object.assign(overlay.style, {
      position: 'fixed', top: 0, left: 0,
      width: '100vw', height: '100vh',
      background: 'transparent',
      zIndex: 9999
    });
    document.body.appendChild(overlay);

    const rect = icon.getBoundingClientRect();
    const clientX = e.touches ? e.touches[0].clientX : e.clientX;
    const clientY = e.touches ? e.touches[0].clientY : e.clientY;

    offsetX = clientX - rect.left;
    offsetY = clientY - rect.top;

    startX = clientX;
    startY = clientY;
  }

  function drag(e) {
    if (!isDown) return;
    e.preventDefault();

    const clientX = e.touches ? e.touches[0].clientX : e.clientX;
    const clientY = e.touches ? e.touches[0].clientY : e.clientY;

    const iconRect = icon.getBoundingClientRect();
    const iconWidth = iconRect.width;
    const iconHeight = iconRect.height;

    const windowWidth = window.innerWidth;
    const windowHeight = window.innerHeight;
    const scrollbarWidth = getScrollbarWidth();

    let left = clientX - offsetX;
    let top = clientY - offsetY;

    left = Math.min(Math.max(left, 0), windowWidth - iconWidth - scrollbarWidth);
    top = Math.min(Math.max(top, 0), windowHeight - iconHeight);

    icon.style.left = left + 'px';
    icon.style.top = top + 'px';

    moved = true;
  }

  function endDrag(e) {
    if (!isDown) return;
    isDown = false;

    const clientX = e.changedTouches ? e.changedTouches[0].clientX : e.clientX;
    const clientY = e.changedTouches ? e.changedTouches[0].clientY : e.clientY;

    const distance = Math.hypot(clientX - startX, clientY - startY);
    if (distance < 5) moved = false;

    const iconRect = icon.getBoundingClientRect();
    const windowWidth = window.innerWidth;
    const iconWidth = iconRect.width;
    const scrollbarWidth = getScrollbarWidth();

    if (iconRect.left + iconWidth / 2 < windowWidth / 2) {
      icon.style.left = '0px';
    } else {
      icon.style.left = (windowWidth - iconWidth - scrollbarWidth) + 'px';
    }

    localStorage.setItem('whatsappPosition', JSON.stringify({
      leftPercent: (parseFloat(icon.style.left) / (window.innerWidth - iconWidth - scrollbarWidth)) * 100,
      topPercent: (parseFloat(icon.style.top) / (window.innerHeight - iconRect.height)) * 100
    }));

    if (overlay) overlay.remove();

    icon.style.transition = 'transform 0.2s ease, left 0.2s ease, top 0.2s ease';
  }

  icon.addEventListener('mousedown', startDrag);
  icon.addEventListener('touchstart', startDrag, { passive: false });

  document.addEventListener('mousemove', drag);
  document.addEventListener('touchmove', drag, { passive: false });

  document.addEventListener('mouseup', endDrag);
  document.addEventListener('touchend', endDrag);

  icon.addEventListener('click', (e) => {
    if (moved) return;

    const phone = "{{ theme.phone_whatsapp }}";
    const message = "{{ theme.message_whatsapp }}";

    window.open(`https://wa.me/${phone}?text=${encodeURIComponent(message)}`, '_blank');
  });
});
</script>