{% comment %}
Promotions Banner Section — Glamour Theme v2.1
A bold split-layout promotional area with image, text, and CTA.
Scoped by section.id for multi-instance support.
{% endcomment %}

{% assign is_rtl = request.is_rtl %}
{% assign bg_color = section.settings.bg_color | default: '#FCE4EC' %}

<section id="promo-{{ section.id }}" class="promotions-banner gl-section" data-banner-section="{{ section.id }}"
  style="{% if section.settings.show_image %} background: url({{ section.settings.bg_image }}) no-repeat center center; background-size: cover; {% else %} background: {{ section.settings.bg_color }}; {% endif %}">
  <div class="gl-container banners-wrapper ">
    <div class="content" data-sal="slide-left"
  data-sal-duration="900"
  data-sal-easing="ease-out-back">
      {% if section.settings.heading != blank or section.settings.heading_ar %}
      <h2 class="heading">
        {% if is_rtl %}
        {{section.settings.heading_ar}}
        {% else %}
        {{section.settings.heading}}
        {% endif %}
      </h2>
      {% endif %}
      {% if section.settings.subtitle != blank or section.settings.subtitle_ar %}
      <p class="subtitle-promotions">
        {% if is_rtl %}
        {{section.settings.subtitle_ar}}
        {% else %}
        {{section.settings.subtitle}}
        {% endif %}
      </p>
      {% endif %}
      {% if section.settings.flash_sale_ends_at != blank %}
      <div class="count-down" data-end-date="{{ section.settings.flash_sale_ends_at }}">
        <div class="countdown-wrapper">
          <div class="countdown-item">
            <span class="countdown-number" id="seconds-{{ section.id }}">00</span>
            <span class="countdown-label">ثواني</span>
          </div>
          <div class="countdown-item">
            <span class="countdown-number" id="minutes-{{ section.id }}">00</span>
            <span class="countdown-label">دقائق</span>
          </div>
          <div class="countdown-item">
            <span class="countdown-number" id="hours-{{ section.id }}">00</span>
            <span class="countdown-label">ساعات</span>
          </div>
          <div class="countdown-item">
            <span class="countdown-number" id="days-{{ section.id }}">00</span>
            <span class="countdown-label">أيام</span>
          </div>
        </div>
      </div>
      {% endif %}
      {% if section.settings.cta_text != blank or section.settings.cta_text_ar %}
      <a class="btn" href="{{section.settings.cta_url}}">
        {% if is_rtl %}
        {{section.settings.cta_text_ar}}
        {% else %}
        {{section.settings.cta_text}}
        {% endif %}
      </a>
      {% endif %}

    </div>
    <div class="swiper hero-swiper" data-sal="slide-right"
  data-sal-duration="900"
  data-sal-delay="150"
  data-sal-easing="ease-out-back">
      <div class="banner-wrapper swiper-wrapper">
        {% for item in section.settings.mini_banners %}
        <div class="banner-item swiper-slide ">
          <div class="image-wrapper">
            {% if is_rtl %}
            <img src="{{ item.image_ar }}" alt="">
            {% else %}
            <img src="{{ item.image }}" alt="">
            {% endif %}
          </div>
        </div>
        {% endfor %}
      </div>
      {%- if section.settings.show_pagination -%}
      <div class="swiper-pagination" id="hero-pagination-{{ section.id }}"></div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .promotions-banner {
    overflow: hidden;
  }

  .promotions-banner .banners-wrapper {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    align-items: center;
    justify-content: center;
    gap: 20px;
  }

  .promotions-banner .hero-swiper {
    width: 100%;
    height: 700px;
    overflow: hidden;
    margin: 0;
  }

  .promotions-banner .hero-swiper .image-wrapper {
    width: 100%;
    height: 100%;
  }

  .promotions-banner .hero-swiper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }

  .promotions-banner .content {
    text-align: start;
  }

  .promotions-banner .content .heading {
    font-size: 40px;
    font-weight: bold;
    color: var(--gl-heading);
    margin-bottom: 16px;
  }

  .promotions-banner .content .subtitle-promotions {
    font-size: 20px;
    font-weight: 500;
    color: var(--gl-heading);
    opacity: 0.8;
  }

  .promotions-banner .content .count-down {
    margin-block: 32px;
  }

  .promotions-banner .countdown-wrapper {
    display: flex;
    gap: 16px;
  }

  .promotions-banner .countdown-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    border-radius: 8px;
    padding: 16px 24px;
    min-width: 60px;
    border: 1px solid var(--gl-heading);
  }

  .promotions-banner .countdown-number {
    font-size: 32px;
    font-weight: bold;
    color: var(--gl-heading);
    line-height: 1;
  }

  .promotions-banner .countdown-label {
    font-size: 16px;
    color: var(--gl-heading);
    opacity: 0.7;
    margin-top: 4px;
    text-transform: uppercase;
  }

  .promotions-banner .content .btn {
    font-size: 16px;
    font-weight: bold;
    color: var(--gl-subheading);
    background-color: var(--gl-primary);
    padding: 13px 31px;
    border-radius: 8px;
    overflow: hidden;
    display: inline-block;
  }

  .promotions-banner .swiper-pagination-bullet {
    background: #e8b3b9;
    opacity: 1;
    width: 12px;
    height: 12px;
    margin: 0 4px;
  }

  .promotions-banner .swiper-pagination-bullet-active {
    background: var(--gl-primary) !important;
    width: 37px !important;
    border-radius: 8px !important;
  }

  @media (max-width: 768px) {
    .promotions-banner .banners-wrapper {
      grid-template-columns: repeat(1, 1fr);
      gap: 20px;
    }

    .promotions-banner .content {
      order: 2;
      margin: auto;
      padding-bottom: 24px;
      text-align: center;
    }

    .promotions-banner .hero-swiper {
      width: 100%;
      height: 260px;
      overflow: hidden;
      margin: 0;
    }

    .promotions-banner .content .heading {
      font-size: 24px;
      font-weight: bold;
      margin-bottom: 8px;
    }

    .promotions-banner .content .subtitle-promotions {
      font-size: 14px;
      font-weight: 400;
      line-height: 20px;
    }

    .promotions-banner .content .count-down {
      margin-block: 16px;
    }

    .promotions-banner .countdown-wrapper {
      gap: 8px;
    }

    .promotions-banner .countdown-item {
      padding: 8px 12px;
      min-width: 50px;
    }

    .promotions-banner .countdown-number {
      font-size: 18px;
    }

    .promotions-banner .countdown-label {
      font-size: 10px;
    }

    .promotions-banner .content .btn {
      font-size: 16px;
      font-weight: bold;
      line-height: 22px;
      color: var(--gl-subheading);
      background-color: var(--gl-primary);
      padding: 10px 23px;
    }

  }
</style>

<script>
  (function () {
    function initCountdown(sectionEl) {
      var countdownEl = sectionEl.querySelector('.count-down');
      if (!countdownEl) return;

      var endDateString = countdownEl.dataset.endDate;
      if (!endDateString) return;

      // Parse the date string in format "MM/DD/YYYY HH:MM AM/PM"
      var endDate = new Date(endDateString);
      var sectionId = sectionEl.id.replace('promo-', '');

      function updateCountdown() {
        var now = new Date().getTime();
        var distance = endDate.getTime() - now;

        if (distance < 0) {
          // Countdown expired
          var daysEl = document.getElementById('days-' + sectionId);
          var hoursEl = document.getElementById('hours-' + sectionId);
          var minutesEl = document.getElementById('minutes-' + sectionId);
          var secondsEl = document.getElementById('seconds-' + sectionId);

          if (daysEl) daysEl.textContent = '00';
          if (hoursEl) hoursEl.textContent = '00';
          if (minutesEl) minutesEl.textContent = '00';
          if (secondsEl) secondsEl.textContent = '00';

          clearInterval(countdownInterval);
          return;
        }

        var days = Math.floor(distance / (1000 * 60 * 60 * 24));
        var hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        var minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        var seconds = Math.floor((distance % (1000 * 60)) / 1000);

        var daysEl = document.getElementById('days-' + sectionId);
        var hoursEl = document.getElementById('hours-' + sectionId);
        var minutesEl = document.getElementById('minutes-' + sectionId);
        var secondsEl = document.getElementById('seconds-' + sectionId);

        if (daysEl) daysEl.textContent = days.toString().padStart(2, '0');
        if (hoursEl) hoursEl.textContent = hours.toString().padStart(2, '0');
        if (minutesEl) minutesEl.textContent = minutes.toString().padStart(2, '0');
        if (secondsEl) secondsEl.textContent = seconds.toString().padStart(2, '0');
      }

      updateCountdown();
      var countdownInterval = setInterval(updateCountdown, 1000);
    }

    function initSubBannerSection(sectionEl) {
      var swiperEl = sectionEl.querySelector('.hero-swiper');
      if (!swiperEl) return;


      var swiper = new Swiper(swiperEl, {
        effect: 'fade',
        fadeEffect: {
          crossFade: true,
        },
        loop: true,
        pagination: {
          el: sectionEl.querySelector('.swiper-pagination'),
          clickable: true,
        },
        navigation: {
          nextEl: sectionEl.querySelector('.swiper-button-next'),
          prevEl: sectionEl.querySelector('.swiper-button-prev'),
        },
      });

      // Initialize countdown
      initCountdown(sectionEl);
    }

    function initAllSubBanners() {
      var sections = document.querySelectorAll('[data-banner-section]');
      sections.forEach(function (section) {
        initSubBannerSection(section);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAllSubBanners);
    } else {
      initAllSubBanners();
    }
  })();
</script>