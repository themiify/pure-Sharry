{% comment %}
  Category Carousel Section — Glamour Theme v2.4.5
  ZID/Shopify-style "Shop by Category" header + auto-scrolling product carousel.
  - Tenant picks ONE category (type: category) — ALL products in that category are loaded.
  - JS fetches /api/products?category_id=X at runtime via category-carousel.js.
  - Falls back to collections.featured placeholders when no category is selected.
  - Buttons use data-gl-action — handled by glamour-pro.js event delegation.
{% endcomment %}

{% assign is_rtl = request.is_rtl %}
{% assign category_id = section.settings.category_id %}
{% assign heading = section.settings.heading | default: 'Shop the Collection' %}
{% assign heading_ar = section.settings.heading_ar | default: 'تسوق المجموعة' %}
{% assign subtitle = section.settings.subtitle %}
{% assign subtitle_ar = section.settings.subtitle_ar %}
{% assign autoplay = section.settings.autoplay | default: true %}
{% assign autoplay_speed = section.settings.autoplay_speed | default: 3000 %}
{% assign show_dots = section.settings.show_dots | default: true %}
{% assign show_arrows = section.settings.show_arrows | default: true %}
{% assign view_all_label = translations.general.view_all | default: 'View All' %}
{% assign add_to_cart_label = translations.product.add_to_cart | default: 'Add to Cart' %}
{% assign add_to_wishlist_label = translations.product.add_to_wishlist | default: 'Add to Wishlist' %}
{% assign remove_from_wishlist_label = translations.product.remove_from_wishlist | default: 'Remove from Wishlist' %}
{% assign sale_label = translations.product.sale | default: 'Sale' %}
{% assign new_label = translations.product.new | default: 'New' %}
{% assign quick_view_label = translations.product.quick_view | default: 'Quick View' %}

{% comment %} Unique instance ID to support multiple carousels on same page {% endcomment %}
{% assign carousel_id = 'gl-cc-' | append: section.settings.category_id | append: '-' | append: 'ps' %}

<section
  class="gl-section gl-category-carousel"
  style="{% assign pad = section.settings.section_padding %}{% if section.settings.section_bg_color != blank %}background-color: {{ section.settings.section_bg_color }};{% endif %}{% if pad %}padding: {{ pad.top | default: 72 }}px {{ pad.right | default: 0 }}px {{ pad.bottom | default: 72 }}px {{ pad.left | default: 0 }}px;{% endif %}"
  data-section="category-carousel"
  data-carousel-id="{{ carousel_id }}"
  data-category-id="{{ category_id }}"
  data-products-url="{{ api_routes.products_index }}"
  data-autoplay="{{ autoplay }}"
  data-autoplay-speed="{{ autoplay_speed }}"
  data-is-rtl="{{ is_rtl }}"
  data-add-to-cart-url="{{ api_routes.cart_store }}"
  data-wishlist-url="{{ api_routes.wishlist_store }}"
  data-wishlist-index-url="{{ api_routes.wishlist_index }}"
  data-compare-url="{{ api_routes.compare_store }}"
  data-compare-index-url="{{ api_routes.compare_index }}"
  data-compare-destroy-url="{{ api_routes.compare_destroy }}"
  data-login-url="{{ api_routes.login_url | default: '/customer/login' }}"
  data-add-to-cart-label="{{ add_to_cart_label }}"
  data-add-to-wishlist-label="{{ add_to_wishlist_label }}"
  data-remove-from-wishlist-label="{{ remove_from_wishlist_label }}"
  data-add-to-compare-label="{{ translations.product.add_to_compare | default: 'Add to Compare' }}"
  data-remove-from-compare-label="{{ translations.product.remove_from_compare | default: 'Remove from Compare' }}"
  data-sale-label="{{ sale_label }}"
  data-new-label="{{ new_label }}"
  data-quick-view-label="{{ quick_view_label }}"
>
  <div class="gl-container">
    <div class="gl-category-carousel-header">
      <div class="gl-category-carousel-header-text">
        <h2 class="gl-category-carousel-title">
          {% if is_rtl and heading_ar != blank %}{{ heading_ar }}{% else %}{{ heading }}{% endif %}
        </h2>
        {% if subtitle != blank or subtitle_ar != blank %}
          <p class="gl-category-carousel-subtitle">
            {% if is_rtl and subtitle_ar != blank -%}
              {{- subtitle_ar -}}
            {%- elsif subtitle != blank -%}
              {{- subtitle -}}
            {%- endif %}
          </p>
        {% endif %}
      </div>
      {% if category_id != blank and category_id != 0 %}
        <a
          href="/search?category_id={{ category_id }}"
          class="gl-btn gl-btn-outline gl-category-carousel-viewall"
        >
          {{ view_all_label }}
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            style="{% if is_rtl %}transform:scaleX(-1);{% endif %}"
          >
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      {% endif %}
    </div>

    {% comment %} Track — populated by JS; placeholder cards shown initially {% endcomment %}
    <div class="gl-cc-viewport" style="overflow:hidden;position:relative;">
      <div
        class="gl-cc-track"
        id="{{ carousel_id }}-track"
        style="display:flex;gap:1.25rem;transition:transform .4s cubic-bezier(.25,.46,.45,.94);will-change:transform;"
      >
        {% comment %} JS replaces these once hydrated {% endcomment %}
        {% assign fallback_products = collections.featured.products | default: empty %}
        {% if fallback_products.size > 0 %}
          {% assign placeholder_count = fallback_products.size %}
        {% else %}
          {% assign placeholder_count = 5 %}
        {% endif %}

        {% for i in (1..placeholder_count) %}
          {% assign fp = fallback_products[forloop.index0] %}
          <div class="gl-product-card gl-cc-card" style="flex:0 0 calc(25% - 1rem);min-width:200px;">
            <div class="gl-product-card-image">
              {% if fp and fp.image != blank %}
                <a href="{{ fp.url }}"><img src="{{ fp.image }}" alt="{{ fp.name }}" loading="lazy"></a>
              {% else %}
                <div class="gl-product-placeholder"></div>
              {% endif %}
              {% if fp %}
                <div class="gl-product-card-badges">
                  {% if fp.is_new -%}
                    <span class="gl-badge gl-badge-accent">{{ new_label }}</span>
                  {%- endif %}
                  {% if fp.special_price -%}
                    <span class="gl-badge gl-badge-hot">{{ sale_label }}</span>
                  {%- endif %}
                </div>
              {% endif %}
            </div>
            <div class="gl-product-card-body">
              {% if fp %}
                <h3 class="gl-product-card-title">
                  <a href="{{ fp.url }}">{{ fp.name }}</a>
                </h3>
                <div class="gl-product-card-price">
                  <span class="current">{{ fp.formatted_price }}</span>
                  {% if fp.special_price -%}
                    <span class="original">{{ fp.formatted_regular_price }}</span>
                  {%- endif %}
                </div>
              {% else %}
                <div
                  style="height:14px;width:70%;background:var(--gl-bg-alt,#f0ecee);border-radius:4px;margin-bottom:8px;animation:gl-shimmer 1.4s ease-in-out infinite;"
                ></div>
                <div
                  style="height:12px;width:40%;background:var(--gl-bg-alt,#f0ecee);border-radius:3px;animation:gl-shimmer 1.4s ease-in-out infinite;"
                ></div>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    {% comment %} Navigation — shown/hidden by CSS based on settings {% endcomment %}
    {% if show_arrows %}
      <button
        class="gl-cc-arrow gl-cc-arrow-prev"
        aria-label="Previous"
        data-carousel="{{ carousel_id }}"
        data-dir="prev"
        style="{% unless show_arrows %}display:none{% endunless %}"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M15 18l-6-6 6-6"/>
        </svg>
      </button>
      <button
        class="gl-cc-arrow gl-cc-arrow-next"
        aria-label="Next"
        data-carousel="{{ carousel_id }}"
        data-dir="next"
        style="{% unless show_arrows %}display:none{% endunless %}"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M9 18l6-6-6-6"/>
        </svg>
      </button>
    {% endif %}

    {% if show_dots %}
      <div class="gl-cc-dots" id="{{ carousel_id }}-dots"></div>
    {% endif %}
  </div>
</section>
