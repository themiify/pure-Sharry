{% comment %}
  Image Gallery Section — Glamour Theme v2.1
{% endcomment %}

{% assign is_rtl = request.is_rtl %}
{% assign interactive_banners = section.settings.interactive_banners | default: empty %}

<section
  style="{% if section.settings.heading_font_override != blank %}--section-font-heading: '{{ section.settings.heading_font_override }}', sans-serif;{% endif %}{% if section.settings.body_font_override != blank %}--section-font-body: '{{ section.settings.body_font_override }}', sans-serif;{% endif %}{% if section.settings.heading_font_size > 0 %}--section-heading-size: {{ section.settings.heading_font_size }}px;{% endif %}{% if section.settings.body_font_size > 0 %}--section-body-size: {{ section.settings.body_font_size }}px;{% endif %}{% assign pad = section.settings.section_padding %}{% if section.settings.section_bg_color != blank %}background-color: {{ section.settings.section_bg_color }};{% endif %} "
  class="gl-section "
>
  <div class="gl-container">
    <div class="interactive-banners-grid">
      {% for item in interactive_banners %}
        {% assign img = item.bg_image %}
        {% if is_rtl and item.bg_image_ar != blank %}
          {% assign img = item.bg_image_ar %}
        {% endif %}

        {% assign display_title = item.main_title %}
        {% if is_rtl and item.main_title_ar != blank %}
          {% assign display_title = item.main_title_ar %}
        {% endif %}
        
        {% assign display_btn = item.btn_text %}
        {% if is_rtl and item.btn_text_ar != blank %}
          {% assign display_btn = item.btn_text_ar %}
        {% endif %}

          <div
        class="interactive-banner "  data-sal="slide-up"
  data-sal-duration="800"
  data-sal-delay="{{ forloop.index0 | times: 150 }}"
  data-sal-easing="ease-out-back"
        style="{% if img != blank %}background-image: url('{{ img }}');{% else %}background-color: var(--gl-primary);{% endif %}"
      >
          <div class="interactive-banner-overlay"></div>
          <div class="interactive-banner-content">

        <div class="interactive-banner-text" data-sal="fade"
  data-sal-duration="900"
  data-sal-delay="{{ forloop.index0 | times: 150 | plus: 200 }}">
              {% if sub_title != blank %}
              <p style="color: {{ item.text_color | default: '#FFFFFF' }};" class="interactive-banner-subtitle">
                {{ sub_title }}
              </p>
            {% endif %}
            {% if display_title != blank %}
              <h3 style="color: {{ item.text_color | default: '#FFFFFF' }};" class="interactive-banner-title">
                {{ display_title }}
              </h3>
            {% endif %}
        </div>
            {% if display_btn != blank  and item.btn_url != blank %}
              <a   data-sal="slide-up"
  data-sal-duration="700"
  data-sal-delay="{{ forloop.index0 | times: 150 | plus: 350 }}" href="{{ item.btn_url | default: '/collections/all' }}" class="interactive-banner-btn ">
                {{ display_btn }}
              </a>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
