{% comment %}
  Breadcrumb Section — Glamour Theme v2.1
  Secondary navigation trail for deeper pages.
{% endcomment %}

{% assign is_rtl = request.is_rtl %}
{% assign separator = section.settings.separator | default: '/' %}
{% assign show_home_icon = section.settings.show_home_icon %}

<nav aria-label="Breadcrumb" >
  <div class="gl-container">
    <ol class="gl-breadcrumb">
      <li>
        <a href="/">
          {% if show_home_icon %}
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
          {% endif %}
          <span>
            {%- if is_rtl %}الرئيسية{% else %}Home{% endif -%}
          </span>
        </a>
      </li>

      {% for crumb in breadcrumbs %}
        <li>
          <span class="gl-breadcrumb-separator" aria-hidden="true">
            {% if separator != blank and separator != '/' %}
              {{ separator }}
            {% else %}
              {% if is_rtl %}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="15 18 9 12 15 6"></polyline>
                </svg>
              {% else %}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="9 18 15 12 9 6"></polyline>
                </svg>
              {% endif %}
            {% endif %}
          </span>
          {% if crumb.url != blank and forloop.last == false %}
            <a href="{{ crumb.url }}">{{ crumb.title }}</a>
          {% else %}
            <span class="active" aria-current="page">{{ crumb.title }}</span>
          {% endif %}
        </li>
      {% endfor %}
    </ol>
  </div>
</nav>
